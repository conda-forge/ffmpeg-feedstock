From d59a68b3b115a7642a24417abbbc43e2e5d74536 Mon Sep 17 00:00:00 2001
From: Mark Harfouche <mark.harfouche@gmail.com>
Date: Wed, 10 Dec 2025 09:50:18 -0500
Subject: [PATCH 4/6] Remove private requirements to help downstream
 compilation

---
 ffbuild/pkgconfig_generate.sh | 2 --
 1 file changed, 2 deletions(-)

diff --git a/ffbuild/pkgconfig_generate.sh b/ffbuild/pkgconfig_generate.sh
index 6e16c635ce..16d23a2e1d 100755
--- a/ffbuild/pkgconfig_generate.sh
+++ b/ffbuild/pkgconfig_generate.sh
@@ -36,10 +36,8 @@ Name: $fullname
 Description: $comment
 Version: $version
 Requires: $($shared || echo $requires)
-Requires.private: $($shared && echo $requires)
 Conflicts:
 Libs: -L\${libdir} $rpath -l${fullname#lib} $($shared || echo $libs)
-Libs.private: $($shared && echo $libs)
 Cflags: -I\${includedir}
 EOF
 
